# Copy to .env.local and fill in. Never commit the filled version.

# --- Site -------------------------------------------------------------------
# Used for canonical URLs, the sitemap, Stripe redirects and the image webhook.
# Must be the real https origin in production — the image provider calls it.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Auth.js / Google sign-in ----------------------------------------------
# AUTH_SECRET: generate with `pnpm dlx auth secret`
AUTH_SECRET=
# Google Cloud Console > APIs & Services > Credentials > OAuth client (Web)
# Authorised redirect URI: <site url>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Cradler (database + storage) ------------------------------------------
CRADLER_URL=https://gateway.cradler.ai
CRADLER_PROJECT_ID=
# Service key — server side only, never expose to the browser.
CRADLER_SERVICE_KEY=

# --- Image generation (apimodels.app) --------------------------------------
APIMODELS_API_KEY=

# HD upscaling uses Real-ESRGAN through the same APIMODELS_API_KEY.

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=

# Price IDs, created in the Stripe dashboard to match src/lib/config.ts
STRIPE_PRICE_PACK_STARTER=      # $9.90  -> 150 credits
STRIPE_PRICE_PACK_POPULAR=      # $24.90 -> 450 credits
STRIPE_PRICE_PACK_PRO=          # $49.90 -> 1100 credits
STRIPE_PRICE_SUB_MONTHLY=       # $19.90 / month, unlimited
STRIPE_PRICE_SUB_YEARLY=        # $159   / year, unlimited
